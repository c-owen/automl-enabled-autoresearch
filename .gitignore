# Python-generated files
__pycache__/
*.py[oc]
build/
dist/
wheels/
*.egg-info

# Virtual environments
.venv
worktrees/
results/
queue/

# Agent prompt files (generated per-session by launchers)
CLAUDE.md
AGENTS.md

# Internal LLM-to-LLM coordination / session handoff notes (local only)
HANDOFF.md

# Experimental code/artifacts
dev/

# Results file
results.tsv

# Trial logs (JSONL ledger, per-trial run.log, session metadata)
logs/

# Test + coverage artifacts
.pytest_cache/
.coverage
htmlcov/

# Local data cache (tabular task downloads live in ~/.cache/autoresearch_tabular/)

# Generated analysis outputs
analysis/
figures/
archive/

# --- experiments/ (Phase-2 grid harness) ---
# program.md is generated per session by start_session.py (= playbook/base.md +
# the arm's enabled sections), like CLAUDE.md/AGENTS.md above. The committed
# source is playbook/base.md + playbook/sections/.
experiments/program.md
# The run-artifact patterns above are global (no leading slash) and already
# match experiments/ subpaths (experiments/logs/, experiments/results.tsv,
# experiments/analysis/, ...). Listed again here, explicitly scoped, so the
# intent survives if a future edit anchors the global patterns to the repo root.
experiments/logs/
experiments/results.tsv
experiments/analysis/
experiments/figures/
experiments/archive/
experiments/.venv/
experiments/.pytest_cache/
# Reference-arm per-run output dirs (Step 9 writes here, never the live session).
experiments/reference_runs/
# data/ is the COMMITTED source of truth, not a cache — force it tracked even if
# a broader ignore is ever introduced above.
!experiments/data/
!experiments/data/**
